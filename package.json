{
  "name": "directus-template-cli",
  "version": "0.7.7",
  "description": "CLI Utility for applying templates to a Directus instance.",
  "author": "bryantgillespie @bryantgillespie",
  "type": "module",
  "bin": {
    "directus-template-cli": "./bin/run.js"
  },
  "homepage": "https://github.com/directus-labs/directus-template-cli",
  "license": "MIT",
  "main": "dist/index.js",
  "repository": "directus-labs/directus-template-cli",
  "files": [
    "/bin",
    "/dist",
    "/npm-shrinkwrap.json",
    "/oclif.manifest.json"
  ],
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@directus/sdk": "21.2.2",
    "@inquirer/prompts": "^8.4.1",
    "@oclif/core": "^4.10.5",
    "@oclif/plugin-help": "^6.2.44",
    "@oclif/plugin-plugins": "^5.4.61",
    "@octokit/rest": "^22.0.1",
    "@sindresorhus/slugify": "^3.0.0",
    "bottleneck": "^2.19.5",
    "chalk": "5.6.2",
    "cli-progress": "^3.12.0",
    "defu": "^6.1.7",
    "dotenv": "^17.4.2",
    "execa": "9.6.1",
    "giget": "^3.2.0",
    "glob": "^13.0.6",
    "log-update": "^8.0.0",
    "nypm": "^0.6.5",
    "pathe": "^2.0.3",
    "posthog-node": "^5.29.2"
  },
  "devDependencies": {
    "@directus/types": "^15.0.2",
    "@eslint/compat": "^2.0.5",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4.1.18",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10",
    "@types/node": "^25.6.0",
    "chai": "^6.2.2",
    "eslint": "^10.2.1",
    "eslint-config-oclif": "^6.0.157",
    "eslint-config-prettier": "^10",
    "mocha": "^11.7.5",
    "oclif": "^4.23.0",
    "prettier": "^3.8.3",
    "shx": "^0.4.0",
    "ts-node": "^10",
    "typescript": "^6.0.3"
  },
  "oclif": {
    "bin": "directus-template-cli",
    "dirname": "directus-template-cli",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {},
    "hooks": {}
  },
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "format": "prettier --write .",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "pnpm run lint",
    "prepack": "pnpm run build && oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "run": "./bin/run.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": "https://github.com/directus-labs/directus-template-cli/issues",
  "keywords": [
    "directus",
    "templates",
    "headless cms",
    "directus cms",
    "directus cli"
  ],
  "types": "dist/index.d.ts",
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
